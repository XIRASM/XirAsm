{
  "$schema": "vscode://schemas/color-theme",
  "name": "XIRASM Dark",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#16181D",
    "editor.foreground": "#D7DAE0",
    "editorLineNumber.foreground": "#5D6472",
    "editorLineNumber.activeForeground": "#C5CAD3",
    "editorCursor.foreground": "#F2CC60",
    "editor.selectionBackground": "#2E4665",
    "editor.inactiveSelectionBackground": "#263343",
    "editor.lineHighlightBackground": "#1E222A",
    "editorIndentGuide.background1": "#2B303A",
    "editorIndentGuide.activeBackground1": "#596273",
    "editorRuler.foreground": "#2B303A",
    "editorWidget.background": "#1B1F27",
    "editorWidget.border": "#303744",
    "sideBar.background": "#14171C",
    "sideBar.foreground": "#B8C0CC",
    "activityBar.background": "#11141A",
    "activityBar.foreground": "#E5E9F0",
    "statusBar.background": "#224E6E",
    "statusBar.foreground": "#F5F7FA",
    "statusBar.noFolderBackground": "#1B1F27",
    "statusBar.debuggingBackground": "#7A5C15",
    "panel.background": "#14171C",
    "panel.border": "#303744",
    "terminal.background": "#16181D",
    "terminal.foreground": "#D7DAE0",
    "list.activeSelectionBackground": "#293D55",
    "list.hoverBackground": "#222832",
    "focusBorder": "#4E9BD8",
    "errorForeground": "#FF6B6B",
    "editorError.foreground": "#FF6B6B",
    "editorWarning.foreground": "#E5C07B",
    "editorInfo.foreground": "#61AFEF",
    "editorHint.foreground": "#7F8998"
  },
  "tokenColors": [
    {
      "scope": [
        "source.xirasm"
      ],
      "settings": {
        "foreground": "#D7DAE0"
      }
    },
    {
      "scope": [
        "comment",
        "comment.line.semicolon.xirasm",
        "comment.line.double-slash.xirasm"
      ],
      "settings": {
        "foreground": "#7EA16B",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.definition.comment.xirasm"
      ],
      "settings": {
        "foreground": "#9BC27E",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string.quoted.double.xirasm",
        "string.quoted.single.xirasm",
        "string.quoted.backtick.xirasm",
        "constant.other.bytes.literal.xirasm"
      ],
      "settings": {
        "foreground": "#D9947A"
      }
    },
    {
      "scope": [
        "constant.character.escape.xirasm"
      ],
      "settings": {
        "foreground": "#F2CC60"
      }
    },
    {
      "scope": [
        "constant.numeric.xirasm",
        "constant.numeric.hex.xirasm",
        "constant.numeric.binary.xirasm",
        "constant.numeric.decimal.xirasm"
      ],
      "settings": {
        "foreground": "#B6D58A"
      }
    },
    {
      "scope": [
        "keyword.control.xirasm",
        "keyword.control.meta.xirasm"
      ],
      "settings": {
        "foreground": "#C891E8",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "keyword.other.definition.xirasm",
        "keyword.other.output.xirasm",
        "keyword.other.meta-block.xirasm",
        "keyword.declaration.function.xirasm",
        "storage.modifier.meta.xirasm"
      ],
      "settings": {
        "foreground": "#61AFEF",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type.data.xirasm",
        "storage.type.meta.xirasm"
      ],
      "settings": {
        "foreground": "#56B6C2"
      }
    },
    {
      "scope": [
        "entity.name.label.xirasm",
        "entity.name.label.area.xirasm"
      ],
      "settings": {
        "foreground": "#7DB7F0",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "variable.other.local-label.xirasm"
      ],
      "settings": {
        "foreground": "#9FC5E8"
      }
    },
    {
      "scope": [
        "entity.name.function.xirasm",
        "entity.name.function.call.xirasm",
        "entity.name.function.meta.xirasm",
        "support.function.meta.xirasm"
      ],
      "settings": {
        "foreground": "#E5C07B"
      }
    },
    {
      "scope": [
        "keyword.mnemonic.x86.xirasm"
      ],
      "settings": {
        "foreground": "#C891E8"
      }
    },
    {
      "scope": [
        "variable.language.register.x86.xirasm"
      ],
      "settings": {
        "foreground": "#8CC6FF"
      }
    },
    {
      "scope": [
        "variable.other.member.xirasm",
        "constant.language.meta.xirasm",
        "variable.language.wildcard.xirasm"
      ],
      "settings": {
        "foreground": "#4FC1FF"
      }
    },
    {
      "scope": [
        "keyword.operator.xirasm"
      ],
      "settings": {
        "foreground": "#ABB2BF"
      }
    },
    {
      "scope": [
        "punctuation.terminator.statement.xirasm",
        "punctuation.separator.xirasm",
        "punctuation.bracket.xirasm"
      ],
      "settings": {
        "foreground": "#9DA5B4"
      }
    }
  ]
}
