// XIRASM COM32 invocation helpers.
//
// The caller supplies the COM method slot offset generated by the Win32
// metadata catalog. Arguments must already follow the selected ABI.

fn com32_call_eax(method_offset: u64) {
    isa("push eax")
    isa("mov eax, [eax]")
    isa(sym.join("call [eax + ", method_offset, "]"))
}

fn com32_invoke(slot_label: string, method_offset: u64) {
    isa(sym.join("mov eax, [", slot_label, "]"))
    com32_call_eax(method_offset)
}
