{
  "name": "xirasm-vscode",
  "displayName": "XIRASM",
  "description": "Language support for XIRASM assembly, Meta language, and format DSL source files.",
  "version": "0.2.1",
  "publisher": "xirasm",
  "license": "MIT",
  "private": true,
  "main": "./out/extension.js",
  "activationEvents": [
    "onLanguage:xirasm"
  ],
  "files": [
    "out",
    "language-configuration.json",
    "syntaxes",
    "snippets",
    "resources",
    "templates",
    "themes",
    "README.md"
  ],
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "xirasm",
    "assembler",
    "assembly",
    "meta",
    "dsl",
    "binary"
  ],
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('out',{recursive:true,force:true})\"",
    "sync:include-resources": "node scripts/sync-include-resources.mjs",
    "generate:language-data": "node scripts/generate-language-data.mjs",
    "check:language-data": "node scripts/check-language-data.mjs",
    "check:lsp-includes": "node scripts/check-lsp-includes.mjs",
    "compile": "npm run sync:include-resources && npm run generate:language-data && npm run check:language-data && npm run clean && tsc -p ./ --noEmit && npm run bundle && npm run check:lsp-includes",
    "bundle": "esbuild src/extension.ts --bundle --platform=node --format=cjs --external:vscode --sourcemap --outfile=out/extension.js && esbuild src/server.ts --bundle --platform=node --format=cjs --sourcemap --outfile=out/server.js && esbuild src/analyzer.ts --bundle --platform=node --format=cjs --sourcemap --outfile=out/analyzer.js",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile",
    "package": "vsce package --allow-missing-repository"
  },
  "contributes": {
    "languages": [
      {
        "id": "xirasm",
        "aliases": [
          "XIRASM",
          "xirasm"
        ],
        "extensions": [
          ".xir",
          ".asm",
          ".inc"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "xirasm",
        "scopeName": "source.xirasm",
        "path": "./syntaxes/xirasm.tmLanguage.json"
      }
    ],
    "themes": [
      {
        "label": "XIRASM Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/xirasm-dark-color-theme.json"
      }
    ],
    "snippets": [
      {
        "language": "xirasm",
        "path": "./snippets/xirasm.code-snippets"
      }
    ],
    "configuration": {
      "title": "XIRASM",
      "properties": {
        "xirasm.diagnostics.assembler.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Run the XIRASM executable on save for compiler-backed diagnostics when an executable can be found."
        },
        "xirasm.diagnostics.assembler.executablePath": {
          "type": "string",
          "default": "",
          "description": "Path to a XIRASM executable. Empty means auto-detect zig-out/bin/xirasm(.exe) under the workspace, then fall back to PATH."
        },
        "xirasm.diagnostics.assembler.timeoutMs": {
          "type": "number",
          "default": 5000,
          "minimum": 250,
          "description": "Timeout for save-time assembler diagnostics."
        }
      }
    },
    "configurationDefaults": {
      "files.associations": {
        "*.xir": "xirasm",
        "*.asm": "xirasm",
        "*.inc": "xirasm"
      }
    }
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.6.3",
    "esbuild": "^0.28.0",
    "typescript": "^5.4.5"
  }
}
