// XIRASM COM64 invocation helpers.
//
// The caller supplies the COM method slot offset generated by the Win32
// metadata catalog. Arguments must already follow the selected ABI.

fn com64_call_rcx(method_offset: u64) {
    isa("mov rax, [rcx]")
    isa(sym.join("call [rax + ", method_offset, "]"))
}

fn com64_invoke(slot_label: string, method_offset: u64) {
    isa(sym.join("mov rcx, [rel ", slot_label, "]"))
    com64_call_rcx(method_offset)
}
