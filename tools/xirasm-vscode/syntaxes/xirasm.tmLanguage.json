{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "XIRASM",
  "scopeName": "source.xirasm",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#labels"
    },
    {
      "include": "#meta"
    },
    {
      "include": "#api"
    },
    {
      "include": "#format"
    },
    {
      "include": "#isa"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.xirasm",
          "match": "(//).*$",
          "captures": {
            "1": {
              "name": "punctuation.definition.comment.xirasm"
            }
          }
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "constant.other.bytes.literal.xirasm",
          "begin": "b\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.xirasm",
              "match": "\"\""
            }
          ]
        },
        {
          "name": "string.quoted.double.xirasm",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.xirasm",
              "match": "\"\""
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.xirasm",
          "match": "\\b0x[0-9A-Fa-f_]+\\b"
        },
        {
          "name": "constant.numeric.binary.xirasm",
          "match": "\\b0b[01_]+\\b"
        },
        {
          "name": "constant.numeric.decimal.xirasm",
          "match": "\\b[0-9][0-9_]*\\b"
        }
      ]
    },
    "labels": {
      "patterns": [
        {
          "name": "entity.name.label.xirasm",
          "match": "^\\s*([A-Za-z_.$@][A-Za-z0-9_.$@]*)\\s*:",
          "captures": {
            "1": {
              "name": "entity.name.label.xirasm"
            }
          }
        },
        {
          "name": "variable.other.local-label.xirasm",
          "match": "\\B\\.[A-Za-z_][A-Za-z0-9_.$@]*\\b"
        }
      ]
    },
    "meta": {
      "patterns": [
        {
          "name": "meta.function.declaration.xirasm",
          "match": "\\b(fn)\\s+([A-Za-z_.$@][A-Za-z0-9_.$@]*)",
          "captures": {
            "1": {
              "name": "keyword.declaration.function.xirasm"
            },
            "2": {
              "name": "entity.name.function.xirasm"
            }
          }
        },
        {
          "name": "keyword.control.xirasm",
          "match": "\\b(if|else|while|for|in|return|break|continue|defer|match|is)\\b"
        },
        {
          "name": "keyword.other.definition.xirasm",
          "match": "\\b(const|let|var|struct|packed|union|enum)\\b"
        },
        {
          "name": "storage.type.xirasm",
          "match": "\\b(u8|u16|u32|u64|i8|i16|i32|i64|usize|bool|string|bytes|list|map|void)\\b"
        },
        {
          "name": "constant.language.xirasm",
          "match": "\\b(true|false|null|target\\.(?:isa|bits))\\b"
        }
      ]
    },
    "api": {
      "patterns": [
        {
          "name": "support.function.xirasm",
          "match": "\\b(?:include|import|print|warn|err|assert|origin|reserve|pad|pad_to|align|db|dw|dd|dq|rb|rw|rd|rq|len|trim|split|join|replace|lower|upper|range)\\b(?=\\s*\\()"
        },
        {
          "name": "support.function.xirasm",
          "match": "\\b(?:emit|store|load|region|virtual|x86|riscv|bytes|list|map|tokens|match|sym|label|fs)\\.[A-Za-z_][A-Za-z0-9_]*\\b(?=\\s*\\()"
        },
        {
          "name": "entity.name.function.call.xirasm",
          "match": "\\b([A-Za-z_.$@][A-Za-z0-9_.$@]*)\\s*(?=\\()",
          "captures": {
            "1": {
              "name": "entity.name.function.call.xirasm"
            }
          }
        }
      ]
    },
    "format": {
      "patterns": [
        {
          "name": "support.function.format.xirasm",
          "match": "\\b(?:pe|coff|elfexe|elfobj|elfso)_[A-Za-z0-9_]+\\b"
        }
      ]
    },
    "isa": {
      "patterns": [
        {
          "name": "keyword.mnemonic.x86.xirasm",
          "match": "^\\s*(?:lock\\s+|rep(?:e|ne)?\\s+)?([A-Za-z][A-Za-z0-9_.]*)(?=\\s|$)",
          "captures": {
            "1": {
              "name": "keyword.mnemonic.xirasm"
            }
          }
        },
        {
          "name": "variable.language.register.x86.xirasm",
          "match": "\\b(?:r(?:ax|bx|cx|dx|sp|bp|si|di|8|9|1[0-5])|e(?:ax|bx|cx|dx|sp|bp|si|di)|[abcd][lh]|[abcd]x|xmm\\d+|ymm\\d+|zmm\\d+|k[0-7])\\b"
        },
        {
          "name": "keyword.mnemonic.spirv.xirasm",
          "match": "\\bOp[A-Za-z0-9_]+\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.xirasm",
          "match": "==|!=|<=|>=|&&|\\|\\||[+\\-*/%&|^~<>]=?|="
        },
        {
          "name": "punctuation.separator.xirasm",
          "match": "[,;:]"
        },
        {
          "name": "punctuation.bracket.xirasm",
          "match": "[{}()\\[\\]]"
        }
      ]
    }
  }
}
